<?xml version="1.0" encoding="utf-8"?>
<me.paranoid.wifikill.AdapterRowLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/RelativeLayout1"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:id="@+id/killed_layout"
        android:background="@drawable/background_killed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignTop="@+id/info"
        android:layout_alignBottom="@+id/info">
        <View
            android:id="@+id/state"
            android:background="#30ff0000"
            android:layout_width="12dp"
            android:layout_height="match_parent"/>
    </LinearLayout>
    <View
        android:id="@+id/killed_shadow"
        android:background="@drawable/shadow_left"
        android:layout_width="8dp"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@+id/killed_layout"
        android:layout_alignTop="@+id/info"
        android:layout_alignBottom="@+id/info"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/info"
        android:paddingLeft="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toRightOf="@+id/killed_layout">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textAppearance="?android:attr/textAppearanceListItem"
                android:id="@+id/ip"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/example_ip"/>
            <TextView
                android:textColor="?android:attr/colorActivatedHighlight"
                android:id="@+id/name"
                android:paddingLeft="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/example_device_name"/>
        </LinearLayout>
        <TextView
            android:textStyle="italic"
            android:textColor="?android:attr/colorActivatedHighlight"
            android:id="@+id/nbname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NetBIOS Name"/>
        <LinearLayout
            android:id="@+id/net_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorHint"
                android:id="@+id/textView1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_label_up"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textStyle="bold"
                android:id="@+id/up"
                android:paddingLeft="2dp"
                android:paddingRight="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/example_1mb"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textColor="?android:attr/textColorHint"
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/device_label_down"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceSmall"
                android:textStyle="bold"
                android:id="@+id/down"
                android:paddingLeft="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/example_1mb"/>
        </LinearLayout>
        <TextView
            android:textAppearance="?android:attr/textAppearanceSmall"
            android:id="@+id/vendor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/example_device_vendor"/>
        <TextView
            android:textColor="?android:attr/textColorHint"
            android:id="@+id/hwaddr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:11:22:33:44:55"/>
    </LinearLayout>
</me.paranoid.wifikill.AdapterRowLayout>
